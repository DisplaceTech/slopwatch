{
  "extends": "./.wxt/tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "jsx": "react-jsx",
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "verbatimModuleSyntax": false,
    "types": ["vitest/globals"]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".wxt/wxt.d.ts"
  ],
  "exclude": [
    "node_modules",
    ".output",
    "tests/e2e",
    "vitest.config.ts",
    "playwright.config.ts"
  ]
}
